# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Mapbox Access Token (optional if using OSRM, required for mapbox routing)
MAPBOX_ACCESS_TOKEN=""

# GraphHopper API Key (optional if using OSRM, required for graphhopper routing)
GRAPHHOPPER_API_KEY=""

# Google Maps API Key (optional if using OSRM, required for google routing)
GOOGLE_MAPS_API_KEY=""

# Application Login Credentials (Stored in .env file)
APP_USERNAME="admin"
APP_PASSWORD="password123"

# Centralized GTFS Regional Configuration Catalog (Map/Dictionary JSON format)
# Consolidates all regional settings: sizeBytes, sha256, DEK, and exact cdnUrl per country, region, and numeric version.
# Note: Zero default values are used; country, region, and version must be explicitly provided on every request.
GTFS_CATALOG='{"EG":{"name":"Egypt","regions":{"cairo":{"422":{"sizeBytes":29360128,"sha256":"e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855","DEK":"cairo-secret-dek-12345","cdnUrl":"https://storage.googleapis.com/multi-transit-gtfs/cairo_gtfs.db"}},"alexandria":{"422":{"sizeBytes":12582912,"sha256":"a1b2c3d4e5f67890123456789abcdef0123456789abcdef0123456789abcdef0","DEK":"alexandria-secret-dek-12345","cdnUrl":"https://storage.googleapis.com/multi-transit-gtfs/alexandria_gtfs.db"}},"train":{"422":{"sizeBytes":15728640,"sha256":"f0e1d2c3b4a5968778695a4b3c2d1e0f9a8b7c6d5e4f3a2b1c0d9e8f7a6b5c4d","DEK":"train-secret-dek-12345","cdnUrl":"https://storage.googleapis.com/multi-transit-gtfs/train_gtfs.db"}}}}}'

